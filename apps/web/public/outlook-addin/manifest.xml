<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">
  <Id>f4d6380a-d92f-4a07-9bb7-9ce2d2fa0c7d</Id>
  <Version>1.0.2.0</Version>
  <ProviderName>Level CRE</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Level CRE Logger"/>
  <Description DefaultValue="Adds your Level CRE intake address to BCC while composing an email."/>
  <IconUrl DefaultValue="https://level-cre.vercel.app/outlook-addin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://level-cre.vercel.app/outlook-addin/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://level-cre.vercel.app/app/inbox"/>
  <AppDomains>
    <AppDomain>https://level-cre.vercel.app</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://level-cre.vercel.app/outlook-addin/taskpane.html?v=1.0.2"/>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="LevelCreComposeGroup">
                <Label resid="Group.Label"/>
                <Control xsi:type="Button" id="LevelCreLogButton">
                  <Label resid="Button.Label"/>
                  <Supertip>
                    <Title resid="Button.Label"/>
                    <Description resid="Button.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>addLevelCreBcc</FunctionName>
                  </Action>
                </Control>
                <Control xsi:type="Button" id="LevelCrePaneButton">
                  <Label resid="PaneButton.Label"/>
                  <Supertip>
                    <Title resid="PaneButton.Label"/>
                    <Description resid="PaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://level-cre.vercel.app/outlook-addin/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://level-cre.vercel.app/outlook-addin/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://level-cre.vercel.app/outlook-addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://level-cre.vercel.app/outlook-addin/commands.html?v=1.0.2"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://level-cre.vercel.app/outlook-addin/taskpane.html?v=1.0.2"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="Group.Label" DefaultValue="Level CRE"/>
        <bt:String id="Button.Label" DefaultValue="Log to Level CRE"/>
        <bt:String id="PaneButton.Label" DefaultValue="Level CRE"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="Button.Tooltip" DefaultValue="Adds your Level CRE intake address to BCC so this email is queued for review."/>
        <bt:String id="PaneButton.Tooltip" DefaultValue="Open the Level CRE logging pane."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
