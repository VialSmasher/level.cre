{
  "name": "@apps/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../../.env tsx -r dotenv/config src/index.ts",
    "build": "esbuild src/index.ts --platform=node --bundle --format=esm --target=node22 --legal-comments=none --outdir=dist --external:@supabase/supabase-js --external:cookie-parser --external:cors --external:dotenv --external:drizzle-orm --external:express --external:helmet --external:jose --external:jsonwebtoken --external:pg --external:zod",
    "start": "npm run build && NODE_ENV=production node dist/index.js",
    "test": "node --import tsx --test src/lib/toolAReview.test.ts src/modules/industrial-intel/surveySyncExtraction.test.ts",
    "check": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:prepare": "node ./scripts/ensure_pgcrypto.mjs && drizzle-kit push",
    "db:migrate-prospect-numerics": "node ./scripts/migrate_prospect_numeric_fields.mjs",
    "intel:migrate": "DOTENV_CONFIG_PATH=../../.env node --import dotenv/config scripts/run_industrial_intel_migrations.mjs",
    "intel:seed": "DOTENV_CONFIG_PATH=../../.env tsx -r dotenv/config scripts/seed-industrial-intel.ts",
    "intel:run-source": "DOTENV_CONFIG_PATH=../../.env tsx -r dotenv/config scripts/run-industrial-intel-source.ts",
    "intel:agent-smoke": "DOTENV_CONFIG_PATH=../../.env tsx -r dotenv/config scripts/smoke-agent-contract.ts"
  },
  "dependencies": {
    "@level-cre/shared": "file:../../packages/shared",
    "@supabase/supabase-js": "^2.55.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.1",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jose": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.16.11",
    "@types/pg": "^8.20.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
