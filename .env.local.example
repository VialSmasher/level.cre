# Local browser configuration only. Copy this file to .env.local and keep the
# real values out of git.
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=
# Enable only after Places API (New) is allowed for the deployed browser key.
VITE_GOOGLE_PLACES_NEW_API=false

# The deterministic UX benchmark uses demo authentication and no production data.
VITE_DEMO_MODE=true
VITE_RUNTIME_OVERLAY=false
