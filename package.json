{
  "name": "level-cre-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm --workspace @apps/web run dev",
    "dev:api": "npm --workspace @apps/api run dev",
    "build": "npm-run-all build:web build:api",
    "vercel-build": "npm run build:web && rm -rf public && mkdir -p public && cp -a apps/web/dist/. public/",
    "build:web": "npm --workspace @apps/web run build",
    "build:api": "npm --workspace @apps/api run build",
    "test:web": "npm --workspace @apps/web run test",
    "test:ux": "playwright test --config playwright.config.ts",
    "test:ux:map": "playwright test --config playwright.map.config.ts",
    "test:ux:all": "npm-run-all --sequential test:ux test:ux:map",
    "test:ux:report": "playwright show-report artifacts/ux-benchmark/playwright-local",
    "start": "npm --workspace @apps/api run start",
    "db:push": "npm --workspace @apps/api run db:push",
    "db:prepare": "npm --workspace @apps/api run db:prepare",
    "intel:migrate": "npm --workspace @apps/api run intel:migrate",
    "intel:seed": "npm --workspace @apps/api run intel:seed",
    "intel:agent-smoke": "npm --workspace @apps/api run intel:agent-smoke"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "drizzle-kit": "^0.30.4",
    "npm-run-all": "^4.1.5"
  }
}
